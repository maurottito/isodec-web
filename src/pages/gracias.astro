---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <Header />
  <main class="gracias">
    <div class="contenedor">
      <p class="etiqueta">Solicitud enviada</p>
      <h1>Gracias por escribirnos</h1>
      <p>
        Recibimos su solicitud y le responderemos en menos de 24 horas a su
        correo con una propuesta técnica preliminar.
      </p>
      <a href="/" class="boton boton--primario">Volver al inicio</a>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .gracias {
    padding-block: 7rem;
    min-height: 45vh;
  }

  .gracias h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: 1rem;
  }

  .gracias p:not(.etiqueta) {
    color: var(--gris);
    max-width: 52ch;
    margin-bottom: 2rem;
  }
</style>
