---
import { Image } from 'astro:assets';
import fotoEdwin from '../assets/equipo-edwin.jpg';
import fotoJuan from '../assets/equipo-juan.jpg';
import fotoMauro from '../assets/equipo-mauro.jpg';
import fotoKesber from '../assets/equipo-kesber.jpg';

const equipo = [
  {
    nombre: 'Edwin Joyo',
    cargo: 'Director Ejecutivo',
    resena:
      'Ingeniero economista por la Universidad Nacional de Ingeniería, especialista en líneas de base social, relaciones comunitarias y valoración económica para Estudios de Impacto Ambiental.',
    correo: 'edwin.joyo@isodec.com.pe',
    linkedin: 'https://www.linkedin.com/in/edwin-joyo-08742126/',
    foto: fotoEdwin,
  },
  {
    nombre: 'Juan Archi',
    cargo: 'Director Social',
    resena:
      'Filósofo y antropólogo por la Universidad Nacional Mayor de San Marcos, especialista en el levantamiento y análisis de información cualitativa en campo.',
    correo: 'juan.archi@isodec.com.pe',
    linkedin: null,
    foto: fotoJuan,
  },
  {
    nombre: 'Mauro Ttito',
    cargo: 'Científico de Datos',
    resena:
      'Magíster en Análisis Computacional y Políticas Públicas por la Universidad de Chicago, especialista en sistemas de inteligencia artificial y plataformas de analítica de datos.',
    correo: 'mauro.ttito@isodec.com.pe',
    linkedin: 'https://www.linkedin.com/in/maurottito',
    foto: fotoMauro,
  },
  {
    nombre: 'Kesber Ángulo Sánchez',
    cargo: 'Consultor Estadístico y en Ciencia de Datos',
    resena:
      'Ingeniero estadístico con más de 18 años de experiencia en análisis estadístico, ciencia de datos e inteligencia artificial, especialista en modelamiento predictivo, desarrollo de indicadores y dashboards para la toma de decisiones.',
    correo: null,
    linkedin: 'https://www.linkedin.com/in/kesber-angulo-s%C3%A1nchez-2b653285',
    foto: fotoKesber,
  },
];
---

<section id="equipo" class="seccion seccion--suave">
  <div class="contenedor">
    <p class="etiqueta">Equipo</p>
    <h2 class="titulo-seccion">Las personas detrás de la evidencia</h2>
    <p class="intro-seccion">
      Economistas, sociólogos, geógrafos y antropólogos con experiencia real de
      campo en todo el Perú.
    </p>

    <div class="equipo__grilla">
      {
        equipo.map((p) => (
          <article class="equipo__tarjeta">
            <div class="equipo__cabecera">
              <div class="equipo__foto">
                <Image
                  src={p.foto}
                  alt={`Retrato de ${p.nombre}`}
                  widths={[180]}
                  sizes="90px"
                  loading="lazy"
                />
              </div>
              <div>
                <h3>
                  {p.nombre}
                  {p.linkedin && (
                    <a href={p.linkedin} target="_blank" rel="noopener" aria-label={`LinkedIn de ${p.nombre}`}>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.34 18.34V10.2H5.67v8.14h2.67zM7 9.09a1.55 1.55 0 1 0 0-3.1 1.55 1.55 0 0 0 0 3.1zm11.34 9.25v-4.46c0-2.39-1.28-3.5-2.98-3.5-1.37 0-1.99.75-2.33 1.28V10.2h-2.67c.04.75 0 8.14 0 8.14h2.67v-4.55c0-.24.02-.48.09-.66.19-.48.63-.97 1.37-.97.96 0 1.35.74 1.35 1.81v4.37h2.5z" />
                      </svg>
                    </a>
                  )}
                </h3>
                <p class="equipo__cargo">{p.cargo}</p>
              </div>
            </div>
            <p class="equipo__resena">{p.resena}</p>
            {p.correo && (
              <a class="equipo__correo" href={`mailto:${p.correo}`}>{p.correo}</a>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .equipo__grilla {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .equipo__tarjeta {
    background: var(--papel);
    border: 1px solid var(--linea);
    border-top: 3px solid var(--ladrillo);
    border-radius: 3px;
    padding: 1.5rem;
  }

  .equipo__cabecera {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .equipo__foto {
    width: 84px;
    height: 84px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: #eceae5;
  }

  .equipo__foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1);
  }

  .equipo__cabecera h3 {
    font-size: 1.0625rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .equipo__cabecera h3 a {
    color: var(--gris);
    display: flex;
  }

  .equipo__cabecera h3 a:hover {
    color: var(--ladrillo);
  }

  .equipo__cargo {
    font-family: var(--fuente-titulos);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ladrillo);
    margin-top: 0.2rem;
  }

  .equipo__resena {
    font-size: 0.9375rem;
    color: var(--gris);
  }

  .equipo__correo {
    display: inline-block;
    margin-top: 0.6rem;
    font-size: 0.875rem;
    color: var(--ladrillo);
    text-decoration: none;
  }

  .equipo__correo:hover {
    text-decoration: underline;
  }

  @media (max-width: 860px) {
    .equipo__grilla {
      grid-template-columns: 1fr;
    }

    .equipo__foto {
      aspect-ratio: 1 / 1;
    }
  }
</style>
